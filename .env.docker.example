# ------------------------------------------------------------------------------
# TenantMind AI - Docker Compose Environment Variables
# ------------------------------------------------------------------------------

# MongoDB Atlas configuration (Replace with your Atlas connection string)
MONGODB_ATLAS_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/platform_db?retryWrites=true&w=majority

# Keycloak Identity Provider (Uses Docker service name inside compose network)
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=tenantmind
KEYCLOAK_CLIENT_ID=backend-client
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret

# Qdrant Vector Database (Uses Docker service name inside compose network)
QDRANT_URL=http://qdrant:6333

# Redis Cache and Message Broker (Uses Docker service name inside compose network)
REDIS_URL=redis://redis:6379/0

# MinIO Object Storage (Uses Docker service name inside compose network)
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=adminpassword
MINIO_SECURE=false

# Ollama local LLM and embedding server (Uses Docker service name inside compose network)
OLLAMA_BASE_URL=http://ollama:11434

# Cloud LLM Provider API Keys
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# TraceNest Logging Configuration
TRACENEST_ENABLED=true
